{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "IFS PL/SQL",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords-program-units" },
    { "include": "#keywords-control" },
    { "include": "#keywords-dml" },
    { "include": "#keywords-ddl" },
    { "include": "#keywords-modifiers" },
    { "include": "#ifs-naming" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.plsql",
          "begin": "--",
          "end": "$"
        },
        {
          "name": "comment.block.plsql",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.plsql",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.plsql", "match": "''" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.plsql",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords-program-units": {
      "comment": "PL/SQL program unit declarations",
      "patterns": [
        {
          "name": "keyword.declaration.plsql",
          "match": "(?i)\\b(PROCEDURE|FUNCTION|PACKAGE|TRIGGER|TYPE|CURSOR|SUBTYPE)\\b"
        },
        {
          "name": "keyword.declaration.plsql",
          "match": "(?i)\\b(CREATE|OR|REPLACE|BODY|FORCE|EDITIONABLE|NONEDITIONABLE)\\b"
        }
      ]
    },
    "keywords-control": {
      "comment": "PL/SQL control flow keywords",
      "patterns": [
        {
          "name": "keyword.control.plsql",
          "match": "(?i)\\b(BEGIN|END|DECLARE|IF|THEN|ELSE|ELSIF|CASE|WHEN|LOOP|WHILE|FOR|EXIT|RETURN|RAISE|EXCEPTION|NULL|GOTO|CONTINUE)\\b"
        },
        {
          "name": "keyword.control.plsql",
          "match": "(?i)\\b(COMMIT|ROLLBACK|SAVEPOINT|PRAGMA|PIPE|ROW|PIPELINED)\\b"
        }
      ]
    },
    "keywords-dml": {
      "comment": "SQL DML keywords used inside PL/SQL",
      "patterns": [
        {
          "name": "keyword.other.dml.plsql",
          "match": "(?i)\\b(SELECT|INSERT|UPDATE|DELETE|MERGE|FROM|WHERE|INTO|VALUES|SET|JOIN|LEFT|RIGHT|FULL|INNER|OUTER|CROSS|ON|USING|GROUP|ORDER|HAVING|UNION|ALL|DISTINCT|ANY|BETWEEN|LIKE|EXISTS|IN|NOT|AND|OR|BY)\\b"
        },
        {
          "name": "keyword.other.dml.plsql",
          "match": "(?i)\\b(BULK|COLLECT|FORALL|RETURNING|EXECUTE|IMMEDIATE|OPEN|FETCH|CLOSE|LIMIT)\\b"
        }
      ]
    },
    "keywords-ddl": {
      "comment": "SQL DDL keywords",
      "patterns": [
        {
          "name": "keyword.other.ddl.plsql",
          "match": "(?i)\\b(TABLE|INDEX|VIEW|SEQUENCE|SYNONYM|GRANT|REVOKE|ALTER|DROP|TRUNCATE|COMMENT|CONSTRAINT|PRIMARY|FOREIGN|UNIQUE|KEY|CHECK|REFERENCES|DEFAULT|NOT)\\b"
        }
      ]
    },
    "keywords-modifiers": {
      "comment": "Parameter and declaration modifiers",
      "patterns": [
        {
          "name": "keyword.other.modifier.plsql",
          "match": "(?i)\\b(IS|AS|IN|OUT|NOCOPY|CONSTANT|AUTHID|CURRENT_USER|DEFINER|DETERMINISTIC|ACCESSIBLE|BY|RESULT_CACHE)\\b"
        },
        {
          "name": "keyword.other.modifier.plsql",
          "match": "(?i)\\b(OBJECT|MEMBER|STATIC|FINAL|INSTANTIABLE|MAP|ORDER|OVERRIDING)\\b"
        }
      ]
    },
    "ifs-naming": {
      "comment": "IFS naming conventions — action/function implementations end with __, variables end with _",
      "patterns": [
        {
          "name": "entity.name.function.ifs.plsql",
          "match": "\\b[A-Za-z][A-Za-z0-9_]*__(?=\\s*[\\(;\\s])"
        },
        {
          "name": "variable.other.ifs.plsql",
          "match": "\\b[a-z][a-z0-9_]*_(?=\\s*[,:;)\\s])"
        }
      ]
    },
    "types": {
      "comment": "Oracle data types and collection types",
      "patterns": [
        {
          "name": "storage.type.plsql",
          "match": "(?i)\\b(VARCHAR2|VARCHAR|NVARCHAR2|CHAR|NCHAR|NUMBER|INTEGER|PLS_INTEGER|BINARY_INTEGER|NATURAL|POSITIVE|FLOAT|REAL|DOUBLE|PRECISION|DATE|TIMESTAMP|INTERVAL|BOOLEAN|BLOB|CLOB|NCLOB|RAW|LONG|ROWID|UROWID|XMLTYPE|SDO_GEOMETRY)\\b"
        },
        {
          "name": "storage.type.collection.plsql",
          "match": "(?i)\\b(TABLE|VARRAY|RECORD|OBJECT|REF|CURSOR|SYS_REFCURSOR)\\b"
        },
        {
          "name": "storage.type.rowtype.plsql",
          "match": "\\b\\w+(%ROWTYPE|%TYPE)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.plsql",
          "match": ":="
        },
        {
          "name": "keyword.operator.comparison.plsql",
          "match": "(=>|<>|!=|>=|<=|>|<|=)"
        },
        {
          "name": "keyword.operator.concatenation.plsql",
          "match": "\\|\\|"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.plsql",
          "match": ";"
        },
        {
          "name": "punctuation.section.block.plsql",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.arguments.plsql",
          "match": "[()]"
        }
      ]
    }
  },
  "scopeName": "source.plsql.ifs"
}
